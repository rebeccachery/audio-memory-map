# Server configuration
BACKEND_URL=http://localhost:8000
PORT=8000

# Storage configuration: 'LOCAL' or 'CLOUD'
STORAGE_TYPE=LOCAL

# LOCAL STORAGE CONFIG
LOCAL_DATA_DIR=data
LOCAL_UPLOAD_DIR=uploads

# CLOUD STORAGE CONFIG (Optional: AWS S3 + PostgreSQL)
# AWS_ACCESS_KEY_ID=your-key-here
# AWS_SECRET_ACCESS_KEY=your-secret-here
# AWS_REGION=us-east-1
# S3_BUCKET_NAME=audio-memory-map

# Local Postgres via Docker Compose (see README — Cloud mode local dev)
# POSTGRES_URL=postgresql://postgres:postgres@localhost:5432/disaster_signals
